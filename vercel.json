{
  "version": 2,

  "builds": [
    {
      "src": "webhook.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/dashboards/(.*)",
      "dest": "/public/dashboards/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}