{
  "builds": [
    {
      "src": "webhook.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/dashboards/(.*)",
      "dest": "/public/dashboards/$1"
    },
    {
      "src": "/api/leap-data",
      "dest": "/api/leap-data.js"
    },
    {
      "src": "/api/leap-upload",
      "dest": "/api/leap-upload.js"
    },
    {
      "src": "/(.*)",
      "dest": "webhook.py"
    }
  ]
}